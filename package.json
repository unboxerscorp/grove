{
  "name": "grove",
  "version": "0.8.0",
  "description": "Grow a tree of AI agents (Claude Code + Codex) in your terminal. Declare an org-chart, bring the whole tree up in tmux, and let any node delegate work to its children.",
  "type": "module",
  "bin": {
    "grove": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check:ts": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test",
    "check:py": "cd bridge && uv run --group dev ruff check . && uv run --group dev ruff format --check . && uv run --group dev mypy src tests && uv run --group dev pytest",
    "check": "pnpm check:ts && pnpm check:py",
    "hooks:install": "lefthook install",
    "prepublishOnly": "pnpm build"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "prettier --write",
      "eslint --fix --max-warnings=0 --no-warn-ignored"
    ],
    "*.{json,md,mdx,yml,yaml,css}": "prettier --write",
    "bridge/**/*.py": [
      "uv run --project bridge --group dev ruff format",
      "uv run --project bridge --group dev ruff check --fix"
    ]
  },
  "keywords": [
    "ai",
    "agents",
    "orchestration",
    "claude",
    "claude-code",
    "codex",
    "tmux",
    "multi-agent",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.6.0",
    "lefthook": "^2.1.9",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^2.1.8"
  }
}
